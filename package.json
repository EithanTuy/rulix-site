{
  "name": "rulix-eccn",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx server/index.ts",
    "prestart": "npm run build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json",
    "build": "npm run typecheck && vite build",
    "build:lambda": "npm run typecheck && vite build && node scripts/build-lambda.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:bundle": "npm run build && node scripts/check-bundle-budgets.mjs",
    "e2e:server": "tsx scripts/start-e2e.ts",
    "test:ai": "cmd /c scripts\\run-live-test.cmd server/test-live-ai.ts",
    "test:ai:deep": "cmd /c scripts\\run-live-test.cmd server/test-live-council.ts",
    "download:corpus": "node scripts/download-official-corpus.mjs",
    "migrate:workspace-v2": "tsx scripts/migrate-workspace-v2.ts",
    "replay:audit-outbox": "tsx scripts/replay-audit-outbox.ts",
    "gc:workspace-content": "tsx scripts/gc-workspace-content.ts",
    "migrate:admin-aggregates": "tsx scripts/migrate-admin-aggregates.ts"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.32.0",
    "@anthropic-ai/sdk": "^0.112.3",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-lambda": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/client-secrets-manager": "^3.1090.0",
    "@aws-sdk/client-sesv2": "^3.1090.0",
    "@aws-sdk/client-sts": "^3.1090.0",
    "@aws-sdk/lib-dynamodb": "^3.1090.0",
    "@aws-sdk/util-dynamodb": "^3.996.7",
    "@fontsource/instrument-serif": "^5.3.0",
    "@fontsource/inter": "^5.3.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serverless-http": "^4.0.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "yaml": "2.9.0"
  }
}
